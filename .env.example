BERTSCOPE_ENVIRONMENT=production
BERTSCOPE_API_KEY=replace-with-a-long-random-secret
BERTSCOPE_API_KEY_ID=compose-admin
BERTSCOPE_API_KEY_ROLE=admin
BERTSCOPE_PUBLIC_BASE_URL=http://localhost:8501
BERTSCOPE_WORKER_CONCURRENCY=1
BERTSCOPE_DATABASE_URL=sqlite:///artifacts/bertscope.db
BERTSCOPE_MODEL_CACHE_DIR=artifacts/model-cache
BERTSCOPE_ALLOW_MODEL_DOWNLOADS=false
BERTSCOPE_INFERENCE_TIMEOUT_SECONDS=30
BERTSCOPE_ALLOWED_ORIGINS=http://localhost:8501
BERTSCOPE_MAX_REQUEST_BYTES=1000000
BERTSCOPE_RATE_LIMIT_REQUESTS=120
BERTSCOPE_RATE_LIMIT_WINDOW_SECONDS=60
BERTSCOPE_REDACT_ARTIFACTS=true
BERTSCOPE_RETENTION_DAYS=30
BERTSCOPE_AUDIT_LOG_PATH=artifacts/audit/audit.jsonl
WEB_CONCURRENCY=2
